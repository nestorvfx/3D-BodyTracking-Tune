# ───────────────────────────────────────────────────────────────────
# Assets — everything in assets/ is downloaded/extracted by setup scripts
# on Vast.  The repo holds only code + manifests.
# ───────────────────────────────────────────────────────────────────
# Apache-2.0 BlazePose .task weights (downloaded from Google CDN by vast_setup.sh)
assets/pose_landmarker_*.task
# Hand + Face .task (auto-downloaded by training/teachers.py on first run)
assets/teachers/
# Open Images V7 sim2real corpus (regenerated by tooling/_iter_*_openimages.* scripts)
assets/sim2real_refs/
# Inspection-time unpacked .task dirs (regenerable via model/inspect_task.py)
assets/*_unpacked/
# Test videos (not used by training; benchmark uses Ego-Exo4D)
assets/testvideo*.mp4

# ───────────────────────────────────────────────────────────────────
# Benchmark transient + bulky outputs
# ───────────────────────────────────────────────────────────────────
# Ego-Exo4D val raw download (~150 MB after trim, re-pulled via egoexo CLI)
benchmark/raw/
# Extracted benchmark JPEGs (~1.1 GB, rebuilt via benchmark/stream_extract.py)
benchmark/frames/
# Cached BlazePose predictions per-variant (rebuilt via benchmark/run_eval.py)
benchmark/predictions/
# Rendered skeleton overlays
benchmark/results/overlays/
# Stream extract / scratch logs
benchmark/_smoke_subset.json
benchmark/_new_only_subset.json
benchmark/*.log

# Open Images V7 raw scratch (re-extracted via tooling/_iter_extract_openimages.py)
tooling/openimages_*/

# Training-time artifacts (kept on /workspace on Vast, not in git)
training/runs/
training/ckpts/
training/teacher_cache/

# Local synth + Ego-Exo4D corpora (re-pulled on Vast each run)
data/
prep/_tmp/

# Reference assets we copied over from the abandoned project (not used by v2)
reference/

# Old per-task model inspection scratch
model/inspection/*_unpacked/

# OS junk
*.bak
*.tmp
*.cache
